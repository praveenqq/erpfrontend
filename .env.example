# Production-like defaults (Keycloak). Set NEXT_PUBLIC_AUTH_MODE=dev only for legacy token bypass.
NEXT_PUBLIC_API_BASE_URL=/api
API_PROXY_TARGET=http://127.0.0.1:8080/api

NEXT_PUBLIC_AUTH_MODE=keycloak
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=erp
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=erp-frontend

NEXT_PUBLIC_TENANT_HEADER=X-Tenant-Id

# Legacy dev-only (not for client demos):
# NEXT_PUBLIC_AUTH_MODE=dev
# NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000002
