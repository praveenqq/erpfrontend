# Same-origin `/api` in dev (proxied by Next.js). Set full URL only if not using the proxy.
NEXT_PUBLIC_API_BASE_URL=/api
API_PROXY_TARGET=http://localhost:8080/api

# Auth: use "dev" for local UI without Keycloak, "keycloak" for OIDC
NEXT_PUBLIC_AUTH_MODE=dev

# Keycloak OIDC (when NEXT_PUBLIC_AUTH_MODE=keycloak)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=erp
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=erp-frontend

# Tenant resolution (subdomain or explicit header in dev)
NEXT_PUBLIC_TENANT_HEADER=X-Tenant-Id
